    "api_host": "0.0.0.0"
  },
  "logging": {
    "log_level": "INFO",
    "log_to_file": true,
    "log_to_console": true,
    "bot_activity_log": "logs/bot_activity.log",
    "order_activity_log": "logs/order_activity.log",
    "rejection_log": "logs/rejection_log.json",
    "exit_log": "logs/exit_log.json",
    "error_log": "logs/error_log.log",
    "max_log_size_mb": 50,
    "backup_count": 5
