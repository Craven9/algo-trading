  "execution": {
    "default_order_type": "marketable_limit",
    "marketable_limit_buffer_percent": 0.25,
    "max_quote_age_seconds": 20,
    "max_trade_age_seconds": 20,
    "confirm_position_before_buy": true,
    "confirm_spread_before_buy": true,
    "confirm_paper_trading_before_buy": true,
    "max_spread_percent_at_execution": 3.0
