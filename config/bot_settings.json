{
  "_comment": "Master control file for the AI Trading Assistant. All modules read from this file via config_loader.py. Edit values here \u2014 do not hardcode settings in source files.",
  "mode": {
    "paper_trading_only": true,
    "dry_run": false,
    "after_hours_scan_only": false,
    "safety_lock": false,
    "allow_live_money": false,
    "manage_open_trades_only": false,
    "bot_enabled": true
  },
  "scanner": {
    "enabled": true,
    "allow_manual_candidates": true,
    "allow_scanner_candidates": true,
    "watchlist_mode": "manual_plus_scanner",
    "min_relative_volume": 0.0,
    "min_day_change_percent": -100.0,
    "max_spread_percent": 100.0,
    "min_dollar_volume": 0,
    "max_price": 1000.0,
    "min_price": 0.01,
    "max_candidates_per_loop": 20,
    "scan_interval_seconds": 60,
    "exclude_otc": true,
    "exclude_etfs": false
  },
  "indicators": {
    "rsi_period": 14,
    "macd_fast": 12,
    "macd_slow": 26,
    "macd_signal": 9,
    "atr_period": 14,
    "ma_fast": 9,
    "ma_slow": 20,
    "volume_ma_period": 20,
    "candle_lookback": 5,
    "max_vwap_extension_pct": 8.0
  },
  "entry_rules": {
    "minimum_setup_score": 78,
    "minimum_probability_score": 75,
    "minimum_final_trade_quality_score": 80,
    "preferred_setup_score": 82,
    "preferred_probability_score": 80,
    "preferred_final_trade_quality_score": 88,
    "minimum_reward_to_risk": 3.0,
    "preferred_reward_to_risk": 5.0,
    "max_entry_extension_percent": 8.0,
    "require_clear_stop": true,
    "require_clear_target": true,
    "require_volume_confirmation": true,
    "require_vwap_confirmation": true,
    "block_failed_reclaims": true,
    "block_hype_only_trades": true,
    "block_if_below_vwap_no_reclaim": true,
    "block_if_under_0618_fib_after_failed_reclaim": true,
    "max_quote_age_seconds": 20,
    "min_reward_to_risk_hard_block": 2.0
  },
  "risk": {
    "max_open_positions": 5,
    "max_daily_loss_dollars": 100,
    "max_position_size_dollars": 250,
    "max_total_exposure_percent": 30,
    "max_risk_dollars_per_trade": 25,
    "minimum_reward_to_risk": 3.0,
    "preferred_reward_to_risk": 5.0,
    "block_new_trades_after_daily_loss": true,
    "reduce_size_after_loss_streak": true,
    "loss_streak_limit": 2,
    "loss_streak_size_reduction_percent": 50,
