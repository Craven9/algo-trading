  "session": {
    "market_open": "09:30",
    "market_close": "16:00",
    "pre_market_start": "04:00",
    "after_hours_end": "20:00",
    "timezone": "America/New_York",
    "avoid_first_minutes": 1,
    "avoid_last_minutes": 5,
    "high_risk_windows": [
      {
        "start": "09:30",
        "end": "09:31",
