    "_comment": "Controls which data source is used for market data. Alpaca handles orders/account. Massive handles market data.",
    "primary_source": "alpaca",
    "live_source": "alpaca",
    "fallback_source": "alpaca",
    "use_massive_rest": false,
    "use_massive_websocket": false,
    "use_flat_files_for_backtest": false,
