    "preferred_retracements": [
      0.382,
      0.5,
      0.618
    ],
    "preferred_extensions": [
      1.272,
      1.618,
      2.0,
      2.618
    ],
    "max_distance_from_fib_level_percent": 2.0,
    "require_vwap_confirmation": true,
    "require_higher_low_confirmation": true,
    "block_if_under_0618_after_failed_reclaim": true
  },
  "exits": {
    "initial_stop_enabled": true,
    "break_even_enabled": true,
    "break_even_trigger_percent": 8.0,
    "break_even_trigger_r_multiple": 1.0,
    "move_stop_to_entry_at_break_even": true,
    "partial_profit_enabled": true,
    "first_partial_percent_gain": 15.0,
    "first_partial_sell_percent": 50,
    "second_partial_extension_level": 1.618,
    "second_partial_sell_percent": 25,
    "trailing_stop_enabled": true,
    "trailing_stop_method": "higher_low",
    "failed_breakout_exit_enabled": true,
    "volume_fade_exit_enabled": true,
    "max_loss_exit_enabled": true,
    "use_fibonacci_extension_targets": true,
    "fibonacci_extension_targets": {
      "target_1_extension": 1.272,
      "target_2_extension": 1.618,
      "runner_extension": 2.0,
      "parabolic_extension": 2.618
