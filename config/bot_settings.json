  "learning": {
    "enabled": true,
    "enable_historical_trade_analyzer": true,
    "minimum_sample_size": 10,
    "max_historical_bonus_points": 5,
    "max_historical_penalty_points": 10,
    "backtest_after_closed_trade": true,
